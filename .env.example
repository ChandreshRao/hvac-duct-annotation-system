# -------------------------------------------------------------------
# HVAC Duct Annotation System – Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------------------

# --- Authentication (choose ONE) ------------------------------------

# Option A: GitHub Models Marketplace (GitHub personal access token)
# https://github.com/marketplace/models
GITHUB_TOKEN=ghp_your_github_token_here

# Option B: OpenAI direct API key
# OPENAI_API_KEY=sk-your_openai_key_here

# --- Model ----------------------------------------------------------
# GitHub Models identifier: gpt-4o
# OpenAI identifier: gpt-4o  or  gpt-4o-2024-11-20
GPT_MODEL=gpt-4o

# --- Tuning ---------------------------------------------------------
GPT_TIMEOUT_SECONDS=60
RENDER_DPI=150
DUCT_MIN_GAP=4.0
DUCT_MAX_GAP=200.0
MAX_UPLOAD_SIZE_MB=50
