# -------------------------------------------------------------------
# HVAC Duct Annotation System – Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------------------

# --- Authentication (choose ONE) ------------------------------------

# Option A: GitHub Models Marketplace (GitHub personal access token)
# https://github.com/marketplace/models
GITHUB_TOKEN=ghp_your_github_token_here

# Option B: OpenAI direct API key
# OPENAI_API_KEY=sk-your_openai_key_here

# --- Model ----------------------------------------------------------
# GitHub Models identifier: gpt-4o
# OpenAI identifier: gpt-4o  or  gpt-4o-2024-11-20
GPT_MODEL=gpt-4o

# --- Tuning ---------------------------------------------------------
GPT_TIMEOUT_SECONDS=60
ENABLE_GPT_FALLBACK=false
ENABLE_OCR_EXTRACTION=false
OCR_LANGUAGE=eng
OCR_DPI=300
USE_OCR_SERVICE=false
OCR_SERVICE_URL=http://localhost:8081/ocr
OCR_SERVICE_TIMEOUT_SECONDS=30
TEXT_CONTEXT_RADIUS_PX=100.0
TEXT_MATCH_MAX_DISTANCE_PX=60.0
TEXT_MATCH_BBOX_MARGIN_PX=24.0
MAX_CANDIDATES_PER_TEXT_ANNOTATION=1
# If running the API inside Docker Compose, set OCR_SERVICE_URL to:
# OCR_SERVICE_URL=http://ocr-service:8081/ocr
RENDER_DPI=150
DUCT_MIN_GAP=4.0
DUCT_MAX_GAP=200.0
MAX_UPLOAD_SIZE_MB=50
MANUAL_ANNOTATIONS_DB_PATH=data/manual_annotations.db
